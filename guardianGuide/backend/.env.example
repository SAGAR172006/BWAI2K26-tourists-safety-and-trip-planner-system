# --- SUPABASE (server-side — NEVER expose to frontend) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- GOOGLE AI (https://aistudio.google.com/app/apikey) ---
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
LLM_MODEL=gemini-2.0-flash
LLM_FALLBACK_MODEL=gemini-1.5-pro

# --- HUGGINGFACE (https://huggingface.co/settings/tokens) ---
HUGGINGFACE_API_KEY=your-hf-token

# --- FOURSQUARE (foursquare.com/developer) ---
FOURSQUARE_API_KEY=your-foursquare-key

# --- UNSPLASH (unsplash.com/developers) ---
UNSPLASH_ACCESS_KEY=your-unsplash-key

# --- TWILIO (twilio.com) ---
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# --- RESEND (resend.com) ---
RESEND_API_KEY=your-resend-key
FROM_EMAIL=onboarding@resend.dev

# --- GOOGLE OAUTH (server-side) ---
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=http://localhost:8080/api/v1/gmail/callback

# --- REDIS ---
REDIS_URL=redis://localhost:6379/0

# --- APP ---
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
SECRET_KEY=change-me-in-production
NOMINATIM_USER_AGENT=GuardianGuide/1.0
